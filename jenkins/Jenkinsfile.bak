
pipeline {
  agent any

  environment {
    DATABRICKS_HOST = credentials('DATABRICKS_HOST')
    DATABRICKS_TOKEN = credentials('DATABRICKS_TOKEN')
  }

  stages {

    stage('Validate') {
      steps {
        sh 'databricks bundle validate'
      }
    }

    stage('Deploy') {
      steps {
        sh 'databricks bundle deploy'
      }
    }

    stage('Run Job') {
      steps {
        sh 'databricks bundle run engineering_intelligence_job'
      }
    }
  }
}
